# ─────────────────────────────────────────────────────────────────
# Production overlay — copy to /.env.prod on the prod host.
# Used by `docker compose -f docker-compose.yml -f docker-compose.prod.yml`.
# Generate strong secrets, do not reuse dev values.
# ─────────────────────────────────────────────────────────────────

POSTGRES_USER=mairie
POSTGRES_PASSWORD=CHANGE-ME-strong-password
POSTGRES_DB=mairie
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Grafana admin login
GRAFANA_ADMIN_PASSWORD=CHANGE-ME

# Frontend build-time URL (consumed by the prebuilt frontend image).
# If you front the app with Apache/Caddy on the host, /api keeps requests
# same-origin so no CORS dance is needed.
VITE_API_URL=/api

# ─────────────────────────────────────────────────────────────────
# Postgres backups
# Mount the NAS share at this host path (see /etc/fstab in
# deploy/apache/mairie.conf header for an SMB example).
# ─────────────────────────────────────────────────────────────────
BACKUP_TARGET=/mnt/mairie-backups

# ─────────────────────────────────────────────────────────────────
# Loki basic-auth (used by Promtail and the Grafana data source).
# Generate the matching bcrypt entry into loki-proxy/htpasswd:
#   htpasswd -nbB mairie 'CHANGE-ME' > loki-proxy/htpasswd
# Then put the same user:password pair here:
# ─────────────────────────────────────────────────────────────────
LOKI_BASIC_AUTH=mairie:CHANGE-ME
