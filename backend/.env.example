# ─────────────────────────────────────────────────────────────────
# backend/.env — copy to backend/.env (gitignored).
# Backend-only secrets and runtime tuning. DB credentials live in
# the root /.env (POSTGRES_*) and are injected by docker-compose.
# ─────────────────────────────────────────────────────────────────

DEBUG=true
TESTING=true

# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE=30

# Mistral OCR
MISTRAL_API_KEY=change-me
MISTRAL_MODEL=mistral-ocr-latest
