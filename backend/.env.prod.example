# ─────────────────────────────────────────────────────────────────
# Production backend secrets — copy to backend/.env.prod on the host.
# Never commit. Generate fresh values, do not reuse dev secrets.
# ─────────────────────────────────────────────────────────────────

DEBUG=false
TESTING=false

# Real domain(s). Comma-separated, no trailing slash.
CORS_ORIGINS=https://inventaire.mairie.example.fr

# JWT — generate with: openssl rand -hex 32
SECRET_KEY=CHANGE-ME
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE=30

# Mistral OCR
MISTRAL_API_KEY=CHANGE-ME
MISTRAL_MODEL=mistral-ocr-latest
