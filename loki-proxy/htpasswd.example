# Generate the real file (gitignored) on the prod host with:
#   sudo apt-get install -y apache2-utils
#   htpasswd -nbB mairie 'CHANGE-ME' > loki-proxy/htpasswd
#
# The matching credentials must go into /.env.prod as:
#   LOKI_BASIC_AUTH=mairie:CHANGE-ME
# Promtail reads that to build its basic_auth header.
# In Grafana → Data sources → Loki, set Basic Auth on with the same
# user/password.
mairie:$2y$05$replace-with-real-bcrypt-hash-from-htpasswd-command
