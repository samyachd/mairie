# ─────────────────────────────────────────────────────────────────
# Root /.env — copy to /.env (gitignored).
# Read by docker-compose for the `db` service init and for port
# substitution in the override files. Also injected into the backend
# container so Pydantic Settings can build DATABASE_URL.
# ─────────────────────────────────────────────────────────────────

# Postgres credentials (used by both the db image and the backend)
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me
POSTGRES_DB=db_inventaire
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Host-side ports
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Frontend prod build (only read when building docker-compose.prod.yml)
# VITE_API_URL=/api

# Grafana admin password (only read by docker-compose.prod.yml)
# GRAFANA_ADMIN_PASSWORD=change-me

# ─────────────────────────────────────────────────────────────────
# Also copy backend/.env.example → backend/.env for the secrets:
#   SECRET_KEY, MISTRAL_API_KEY, CORS_ORIGINS, DEBUG, TESTING
# ─────────────────────────────────────────────────────────────────
