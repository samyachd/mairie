# Node — installed inside the image by `npm ci` in the deps stage,
# never copied from the host (would bloat the image and may contain
# platform-incompatible native modules).
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build outputs — regenerated inside the builder stage
dist/
build/
.vite/
*.tsbuildinfo

# Local env files — secrets and per-developer overrides.
# .env.development / .env.production are read by Vite at build time;
# in this project we pass VITE_API_URL via Docker build ARGs instead.
.env
.env.local
.env.development.local
.env.production.local
.env.development
.env.production

# Git
.git/
.gitignore

# IDE
.vscode/
.idea/
*.swp

# Logs
*.log
logs/

# Tests / coverage
coverage/
.nyc_output/

# Docs
README.md
docs/

# Docker (no need to ship these inside the image)
Dockerfile
.dockerignore
docker-compose*.yml

# OS junk
.DS_Store
Thumbs.db
