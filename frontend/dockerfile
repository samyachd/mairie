# =============================================================
# Dockerfile — Inventaire IT API
# =============================================================
# On part d'une image Python 3.12 "slim" (plus petite = image
# plus legere à télécharger et à shipper)
# =============================================================
FROM python:3.12-slim

# -------------------------------------------------------------
# On crée un utilisateur non-root pour la sécurité.
# Par défaut Docker tourne en root — c'est un risque.
# -------------------------------------------------------------
RUN groupadd -r appuser && useradd -r -g appuser appuser

# -------------------------------------------------------------
# On définit le répertoire de travail dans le conteneur.
# Tout ce qu'on fait après se passe ici.
# -------------------------------------------------------------
WORKDIR /app


COPY requirements.txt .


RUN pip install --no-cache-dir -r requirements.txt

# -------------------------------------------------------------
# On copie le reste du code source.
# Le .dockerignore (fichier séparé) exclut les fichiers inutiles
# comme __pycache__, .env, venv/, etc.
# -------------------------------------------------------------
COPY . .

# -------------------------------------------------------------
# On change le propriétaire des fichiers pour l'utilisateur
# non-root qu'on a créé au-dessus.
# -------------------------------------------------------------
RUN chown -R appuser:appuser /app

# Switcher vers l'utilisateur non-root
USER appuser

# -------------------------------------------------------------
# On expose le port 8000 — c'est celui que FastAPI/Uvicorn
# utilise par défaut. EXPOSE ne "map" pas vraiment le port,
# c'est juste de la documentation pour dire "ce conteneur
# écute sur le port 8000".
# -------------------------------------------------------------
EXPOSE 8000

# -------------------------------------------------------------
# La commande qui se lance quand le conteneur démarre.
# --host 0.0.0.0 : écouter sur toutes les interfaces réseau
#   (pas juste localhost — sinon le conteneur n'est pas
#   accessible de l'extérieur)
# --reload : À RETIRER en production ! En février c'est OK
#   pour du développement. En mai on le supprime.
# -------------------------------------------------------------
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
